# ============================================
# APP
# ============================================
NODE_ENV=development
PORT=3001
APP_URL=http://localhost:3001
FRONTEND_URL=http://localhost:3000

# ============================================
# DATABASE (PostgreSQL via Docker Compose)
# ============================================
DATABASE_URL=postgresql://goalspot:goalspot_secret@localhost:5432/goalspot_db

# ============================================
# REDIS (via Docker Compose)
# ============================================
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# ============================================
# JWT TOKENS
# Access token: short-lived (15 minutes)
# Refresh token: long-lived (7 days)
# ============================================
JWT_SECRET=CHANGE_THIS_TO_A_LONG_RANDOM_STRING_IN_PRODUCTION
JWT_EXPIRES_IN=15m
JWT_REFRESH_SECRET=CHANGE_THIS_TO_ANOTHER_LONG_RANDOM_STRING
JWT_REFRESH_EXPIRES_IN=7d

# ============================================
# OAUTH PROVIDERS
# ============================================
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

FACEBOOK_APP_ID=
FACEBOOK_APP_SECRET=

ONE_ID_CLIENT_ID=
ONE_ID_CLIENT_SECRET=

# ============================================
# CLOUDFLARE R2 (Object Storage for media)
# ============================================
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=goalspot-media
R2_PUBLIC_URL=

# ============================================
# OTP (Phone Authentication)
# ============================================
OTP_TTL_SECONDS=300
OTP_MAX_ATTEMPTS=3

# ============================================
# RATE LIMITING
# ============================================
THROTTLE_TTL=60
THROTTLE_LIMIT=100
